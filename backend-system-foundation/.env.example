# ============================================================================
# Backend System Foundation - Environment Configuration
# ============================================================================
# This file contains all required environment variables for the application.
# Copy this file to .env and update the values for your environment.
#
# SECURITY WARNING: Never commit .env files to version control!
# ============================================================================

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Application name and version
APP_NAME="Backend System Foundation"
APP_VERSION="1.0.0"

# Environment: dev, staging, prod
# - dev: Development environment with debug enabled
# - staging: Pre-production environment for testing
# - prod: Production environment with strict security
ENVIRONMENT=dev

# Enable debug mode (MUST be false in production)
DEBUG=true

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database
# For async support: postgresql+asyncpg://username:password@host:port/database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/triage_db

# Database connection pool settings
# Pool size: Maximum number of connections (Requirement 13.7: max 20)
# Pool min size: Minimum number of connections (Requirement 13.7: min 5)
DB_POOL_SIZE=20
DB_POOL_MIN_SIZE=5

# Enable SQL query logging (MUST be false in production)
DB_ECHO=false

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================

# Redis connection string
# Format: redis://host:port/database
# For TLS: rediss://host:port/database
REDIS_URL=redis://localhost:6379/0

# Maximum number of Redis connections in the pool
REDIS_MAX_CONNECTIONS=50

# ============================================================================
# JWT AUTHENTICATION
# ============================================================================

# JWT secret key for token signing
# CRITICAL: Change this in production! Use a strong random key (32+ characters)
# Generate with: openssl rand -hex 32
# For RS256: Use RSA private key instead
JWT_SECRET_KEY=your-secret-key-change-in-production

# JWT algorithm: RS256 (asymmetric) or HS256 (symmetric)
# REQUIREMENT 14.3: Must be RS256 in production
JWT_ALGORITHM=RS256

# Token expiration times
# Access token: Short-lived token for API requests (Requirement 3.2: 15 minutes)
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token: Long-lived token for obtaining new access tokens (Requirement 3.3: 7 days)
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# Password hashing cost factor (Requirement 1.6: bcrypt cost factor 12)
# Higher values = more secure but slower (range: 10-15)
BCRYPT_COST_FACTOR=12

# Password complexity requirements (Requirement 14.1)
PASSWORD_MIN_LENGTH=12

# Account lockout settings (Requirement 1.7)
# Lock account after this many failed login attempts
MAX_LOGIN_ATTEMPTS=10

# Account lockout duration in minutes
ACCOUNT_LOCKOUT_MINUTES=30

# ============================================================================
# CORS CONFIGURATION
# ============================================================================

# Allowed CORS origins (comma-separated list)
# In production, specify exact origins (no wildcards)
# Example: ["https://app.example.com","https://admin.example.com"]
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Allow credentials (cookies, authorization headers) in CORS requests
CORS_ALLOW_CREDENTIALS=true

# Allowed HTTP methods (default: all)
# CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","PATCH"]

# Allowed HTTP headers (default: all)
# CORS_ALLOW_HEADERS=["*"]

# ============================================================================
# RATE LIMITING
# ============================================================================

# Rate limit per authenticated user (Requirement 10.6: 100 requests/minute)
RATE_LIMIT_PER_MINUTE=100

# Rate limit per IP address (for unauthenticated requests)
RATE_LIMIT_PER_IP_MINUTE=1000

# ============================================================================
# SESSION MANAGEMENT
# ============================================================================

# Session expiration time in minutes (Requirement 3.2: 15 minutes)
SESSION_EXPIRE_MINUTES=15

# Maximum concurrent sessions per user (Requirement 3.5: 5 sessions)
MAX_CONCURRENT_SESSIONS=5

# ============================================================================
# CACHE TTL CONFIGURATION (in seconds)
# ============================================================================

# Session cache TTL (Requirement 12.4: 15 minutes = 900 seconds)
CACHE_TTL_SESSION=900

# Patient record cache TTL (Requirement 12.5: 5 minutes = 300 seconds)
CACHE_TTL_PATIENT=300

# Queue state cache TTL (Requirement 12.6: 1 minute = 60 seconds)
CACHE_TTL_QUEUE=60

# Permission lookup cache TTL (Requirement 12.7: 10 minutes = 600 seconds)
CACHE_TTL_PERMISSION=600

# ============================================================================
# PAGINATION CONFIGURATION
# ============================================================================

# Default page size for paginated results (Requirement 18.1: default 50)
DEFAULT_PAGE_SIZE=50

# Maximum page size (Requirement 18.1: max 100)
MAX_PAGE_SIZE=100

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# Use INFO or WARNING in production
LOG_LEVEL=INFO

# Log format: json or text
# Use json in production for structured logging
LOG_FORMAT=json

# ============================================================================
# SECURITY HARDENING
# ============================================================================

# Enforce HTTPS for all connections (MUST be true in production)
# Requirement 14.2: Use TLS 1.3 for all network connections
ENFORCE_HTTPS=false

# Minimum TLS version (Requirement 14.2: TLSv1.3 in production)
# Options: TLSv1.2, TLSv1.3
TLS_MIN_VERSION=TLSv1.3

# Enable security headers (CSP, HSTS, X-Frame-Options, etc.)
# Requirement 14.7: XSS prevention through Content-Security-Policy headers
ENABLE_SECURITY_HEADERS=true

# Enable XSS protection (Requirement 14.7)
ENABLE_XSS_PROTECTION=true

# Enable SQL injection detection (Requirement 14.6)
ENABLE_SQL_INJECTION_DETECTION=true

# ============================================================================
# API KEYS
# ============================================================================

# Google Gemini API Key (for AI features)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Scaledown API Key (for scaling/optimization features)
# Get your API key from your Scaledown dashboard
SCALEDOWN_API_KEY=your-scaledown-api-key-here

# ============================================================================
# SECRETS MANAGEMENT
# ============================================================================

# Encryption key for secrets at rest (optional)
# Leave empty to disable encryption
# Generate with: openssl rand -hex 32
# CRITICAL: Keep this secret and rotate regularly
SECRETS_ENCRYPTION_KEY=

# ============================================================================
# ENVIRONMENT-SPECIFIC EXAMPLES
# ============================================================================

# --- DEVELOPMENT ENVIRONMENT ---
# ENVIRONMENT=dev
# DEBUG=true
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/triage_db
# REDIS_URL=redis://localhost:6379/0
# JWT_SECRET_KEY=dev-secret-key-not-for-production
# ENFORCE_HTTPS=false
# LOG_LEVEL=DEBUG

# --- STAGING ENVIRONMENT ---
# ENVIRONMENT=staging
# DEBUG=false
# DATABASE_URL=postgresql://user:password@staging-db.example.com:5432/triage_db
# REDIS_URL=redis://staging-redis.example.com:6379/0
# JWT_SECRET_KEY=<generate-strong-key>
# ENFORCE_HTTPS=true
# LOG_LEVEL=INFO
# CORS_ORIGINS=["https://staging.example.com"]

# --- PRODUCTION ENVIRONMENT ---
# ENVIRONMENT=prod
# DEBUG=false
# DATABASE_URL=postgresql://user:password@prod-db.example.com:5432/triage_db
# REDIS_URL=rediss://prod-redis.example.com:6379/0
# JWT_SECRET_KEY=<generate-strong-key>
# JWT_ALGORITHM=RS256
# ENFORCE_HTTPS=true
# TLS_MIN_VERSION=TLSv1.3
# LOG_LEVEL=INFO
# CORS_ORIGINS=["https://app.example.com"]
# ENABLE_SECURITY_HEADERS=true
# ENABLE_XSS_PROTECTION=true
# ENABLE_SQL_INJECTION_DETECTION=true

# ============================================================================
# NOTES
# ============================================================================
# 
# 1. Security Best Practices:
#    - Never commit .env files to version control
#    - Use different secrets for each environment
#    - Rotate secrets regularly (especially JWT keys)
#    - Use strong random keys (32+ characters)
#    - Enable all security features in production
#
# 2. Production Requirements:
#    - DEBUG must be false
#    - ENFORCE_HTTPS must be true
#    - TLS_MIN_VERSION must be TLSv1.3
#    - JWT_ALGORITHM must be RS256
#    - CORS_ORIGINS must not contain wildcards
#    - All security features must be enabled
#
# 3. Performance Tuning:
#    - Adjust DB_POOL_SIZE based on load (max 20 per Requirement 13.7)
#    - Tune cache TTL values based on data volatility
#    - Adjust rate limits based on expected traffic
#
# 4. Monitoring:
#    - Use structured logging (LOG_FORMAT=json) in production
#    - Set appropriate LOG_LEVEL (INFO or WARNING in production)
#    - Monitor rate limit hits and adjust as needed
#
# ============================================================================
