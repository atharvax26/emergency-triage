# ============================================================================
# Frontend Environment Configuration
# ============================================================================
# Copy this file to .env.local and update the values
# SECURITY WARNING: Never commit .env.local to version control!
# ============================================================================

# ============================================================================
# BACKEND API CONFIGURATION
# ============================================================================

# Backend API URL
VITE_API_URL=http://localhost:8000

# ============================================================================
# API KEYS
# ============================================================================

# Google Gemini API Key (for AI features)
# Get your API key from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# Scaledown API Key (for scaling/optimization features)
# Get your API key from your Scaledown dashboard
VITE_SCALEDOWN_API_KEY=your-scaledown-api-key-here

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable AI features
VITE_ENABLE_AI_FEATURES=true

# Enable analytics
VITE_ENABLE_ANALYTICS=false

# ============================================================================
# ENVIRONMENT
# ============================================================================

# Environment: development, staging, production
VITE_ENVIRONMENT=development

# Enable debug mode
VITE_DEBUG=true

# ============================================================================
# NOTES
# ============================================================================
#
# 1. All environment variables must be prefixed with VITE_ to be accessible
#    in the frontend code via import.meta.env.VITE_*
#
# 2. After changing this file, restart the development server
#
# 3. For production, create .env.production with production values
#
# 4. Never commit API keys to version control!
#
# ============================================================================
